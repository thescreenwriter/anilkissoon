<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Anil Kissoon Taxis — Premier Transport, Georgetown, Guyana</title>
  <meta name="description" content="Georgetown's most trusted premium taxi service. Airport transfers, corporate accounts, and guided city tours. Fully licensed H-Series vehicles, GPS tracked, uniformed drivers." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400;1,9..144,600&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <style>
    /* ─── TOKENS ─────────────────────────────────────────── */
    :root {
      --ink:        #0C1810;
      --navy:       #0D1F35;
      --navy-mid:   #122840;
      --navy-light: #1B3A58;
      --amber:      #C9920D;
      --amber-hi:   #E8B535;
      --amber-pale: #F7E8B8;
      --cream:      #F4EDD8;
      --slate:      #7A96AE;
      --muted-g:    #5A7060;
      --white:      #FFFFFF;
      --bd:         rgba(201,146,13,0.2);
      --bdl:        rgba(12,26,18,0.12);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--navy);
      color: var(--white);
      font-size: 16px;
      line-height: 1.65;
      overflow-x: hidden;
    }

    /* ─── HALFTONE ───────────────────────────────────────── */
    .halftone {
      position: absolute; inset: 0; pointer-events: none; z-index: 0;
      background-image: radial-gradient(circle, rgba(201,146,13,0.06) 1px, transparent 1px);
      background-size: 22px 22px;
    }

    /* ─── HEADER ─────────────────────────────────────────── */
    header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 32px;
      background: rgba(13,31,53,0.96);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--bd);
      transition: background 0.4s;
    }
    .logo { text-decoration: none; display: flex; flex-direction: column; gap: 2px; }
    .logo-name {
      font-family: 'Fraunces', serif;
      font-optical-sizing: auto;
      font-size: 1.15rem; font-weight: 600;
      color: var(--white); line-height: 1;
    }
    .logo-sub {
      font-size: 0.58rem; font-weight: 400;
      letter-spacing: 0.24em; text-transform: uppercase;
      color: var(--amber);
    }
    .header-book {
      display: flex; align-items: center; gap: 9px;
      font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase;
      text-decoration: none;
      color: var(--navy); background: var(--amber);
      padding: 10px 20px; border-radius: 40px;
      white-space: nowrap;
      transition: background 0.2s, transform 0.15s;
    }
    .header-book:hover { background: var(--amber-hi); transform: translateY(-1px); }

    /* ─── HERO ───────────────────────────────────────────── */
    .hero {
      position: relative; min-height: 100svh;
      display: grid; grid-template-columns: 1fr;
      align-items: center;
      padding: 100px 32px 80px;
      background: var(--navy); overflow: hidden;
    }
    @media (min-width: 900px) { .hero { grid-template-columns: 1fr 420px; gap: 40px; } }

    .hero-mesh {
      position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse 80% 60% at 80% 30%, rgba(201,146,13,0.08) 0%, transparent 60%),
        radial-gradient(ellipse 50% 70% at 10% 80%, rgba(27,58,88,0.5) 0%, transparent 60%);
      animation: meshShift 14s ease-in-out infinite alternate;
    }
    @keyframes meshShift {
      0%   { opacity: 1; }
      100% { opacity: 0.7; }
    }

    .hero-content { position: relative; z-index: 1; }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 12px;
      font-size: 0.68rem; font-weight: 400;
      letter-spacing: 0.26em; text-transform: uppercase;
      color: var(--amber); margin-bottom: 28px;
    }
    .eyebrow-line { display: block; width: 36px; height: 1px; background: var(--amber); }

    .hero h1 {
      font-family: 'Fraunces', serif;
      font-optical-sizing: auto;
      font-size: clamp(3rem, 8vw, 5.8rem);
      font-weight: 600; line-height: 1.04;
      letter-spacing: -0.02em;
      color: var(--white); margin-bottom: 30px;
    }
    .hero h1 .italic-line {
      display: block; font-style: italic;
      font-weight: 300; color: var(--amber);
    }
    .hero-sub {
      font-size: 1rem; font-weight: 300;
      color: var(--slate); max-width: 480px;
      line-height: 1.8; margin-bottom: 44px;
    }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }

    .btn-wa {
      display: inline-flex; align-items: center; gap: 10px;
      font-size: 0.82rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.1em;
      text-decoration: none;
      color: var(--navy); background: var(--amber);
      padding: 15px 28px; border-radius: 40px;
      box-shadow: 0 6px 28px rgba(201,146,13,0.3);
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    }
    .btn-wa:hover { background: var(--amber-hi); transform: translateY(-2px); box-shadow: 0 10px 36px rgba(201,146,13,0.4); }

    .btn-ghost {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 0.8rem; font-weight: 300;
      letter-spacing: 0.06em; text-decoration: none;
      color: rgba(255,255,255,0.55);
      padding-bottom: 3px;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      transition: color 0.2s, border-color 0.2s;
    }
    .btn-ghost:hover { color: var(--amber); border-color: var(--amber); }

    /* Georgetown civic silhouette — desktop only */
    .hero-graphic {
      display: none; position: relative; z-index: 1;
      align-items: flex-end; justify-content: center;
      height: 380px;
    }
    @media (min-width: 900px) { .hero-graphic { display: flex; } }
    .city-svg { width: 100%; max-width: 400px; }

    /* ─── TRUST STRIP ────────────────────────────────────── */
    .trust-strip {
      background: rgba(255,255,255,0.025);
      border-top: 1px solid var(--bd);
      border-bottom: 1px solid var(--bd);
      padding: 0 32px; overflow-x: auto; scrollbar-width: none;
    }
    .trust-strip::-webkit-scrollbar { display: none; }
    .trust-inner {
      display: flex; min-width: max-content;
      max-width: 1100px; margin: 0 auto;
    }
    .t-item {
      display: flex; align-items: center; gap: 11px;
      padding: 18px 32px;
      border-right: 1px solid var(--bd);
      white-space: nowrap;
    }
    .t-item:first-child { padding-left: 0; }
    .t-item:last-child { border-right: none; }
    .t-ico { color: var(--amber); flex-shrink: 0; }
    .t-lbl {
      font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--white); line-height: 1.3;
    }
    .t-lbl small {
      display: block; font-weight: 300;
      letter-spacing: 0.04em; text-transform: none;
      color: var(--slate); font-size: 0.67rem; margin-top: 1px;
    }

    /* ─── SECTION SCAFFOLDING ────────────────────────────── */
    section { padding: 96px 32px; position: relative; }
    .si { max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }

    .eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      font-size: 0.62rem; font-weight: 400;
      letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--amber); margin-bottom: 12px;
    }
    .eyebrow::before { content: ''; display: block; width: 22px; height: 1px; background: var(--amber); }

    h2.st {
      font-family: 'Fraunces', serif;
      font-optical-sizing: auto;
      font-size: clamp(2rem, 4.5vw, 3.2rem);
      font-weight: 500; line-height: 1.1;
      color: var(--white); margin-bottom: 18px;
    }
    h2.st em { font-style: italic; font-weight: 300; color: var(--amber); }
    h2.st.ink { color: var(--ink); }
    h2.st.ink em { color: var(--amber); }

    .sb {
      font-size: 0.93rem; font-weight: 300;
      color: var(--slate); max-width: 520px;
      line-height: 1.8; margin-bottom: 48px;
    }
    .sb.ink { color: var(--muted-g); }

    .amber-rule { width: 44px; height: 3px; background: var(--amber); border-radius: 2px; margin: 16px 0 44px; }

    /* ─── SERVICES ───────────────────────────────────────── */
    #services { background: var(--navy-mid); }

    .svc-list { display: flex; flex-direction: column; gap: 2px; }
    .svc-card {
      display: grid; grid-template-columns: 56px 1fr auto;
      align-items: center; gap: 28px;
      padding: 32px 36px;
      background: var(--navy);
      border: 1px solid var(--bd);
      position: relative; overflow: hidden;
      transition: background 0.25s, border-color 0.25s;
    }
    .svc-card::before {
      content: ''; position: absolute;
      left: 0; top: 0; bottom: 0; width: 3px;
      background: var(--amber);
      transform: scaleY(0); transform-origin: bottom;
      transition: transform 0.3s ease;
    }
    .svc-card:hover { background: rgba(255,255,255,0.02); border-color: rgba(201,146,13,0.4); }
    .svc-card:hover::before { transform: scaleY(1); }
    .svc-n {
      font-family: 'Fraunces', serif; font-size: 2.4rem;
      font-weight: 300; font-style: italic;
      color: rgba(201,146,13,0.18); line-height: 1; text-align: center;
    }
    .svc-title {
      font-family: 'Fraunces', serif; font-optical-sizing: auto;
      font-size: 1.28rem; font-weight: 500;
      color: var(--white); margin-bottom: 6px;
    }
    .svc-desc { font-size: 0.875rem; font-weight: 300; color: var(--slate); line-height: 1.7; }
    .svc-pill {
      font-size: 0.6rem; font-weight: 500;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--amber); border: 1px solid var(--bd);
      padding: 6px 14px; border-radius: 20px; white-space: nowrap; flex-shrink: 0;
    }
    @media (max-width: 640px) {
      .svc-card { grid-template-columns: 40px 1fr; gap: 14px; padding: 22px 18px; }
      .svc-pill { display: none; }
    }

    /* ─── HOW IT WORKS ───────────────────────────────────── */
    #how { background: var(--cream); }

    .steps { display: grid; grid-template-columns: 1fr; gap: 0; }
    @media (min-width: 680px) { .steps { grid-template-columns: repeat(3,1fr); } }

    .step {
      padding: 40px 34px; position: relative;
      border-bottom: 1px solid var(--bdl);
    }
    @media (min-width: 680px) {
      .step { border-bottom: none; border-right: 1px solid var(--bdl); }
      .step:last-child { border-right: none; }
    }
    .step-n {
      font-family: 'Fraunces', serif; font-size: 3.8rem;
      font-weight: 300; font-style: italic;
      color: rgba(201,146,13,0.16); line-height: 1; margin-bottom: 16px;
    }
    .step-title {
      font-size: 0.78rem; font-weight: 500;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink); margin-bottom: 10px;
    }
    .step-desc { font-size: 0.875rem; font-weight: 300; color: var(--muted-g); line-height: 1.75; }

    /* ─── FOUNDER ────────────────────────────────────────── */
    #founder { background: var(--navy); padding: 0 32px; }
    .founder-shell {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr;
      border-top: 1px solid var(--bd); border-bottom: 1px solid var(--bd);
    }
    @media (min-width: 768px) { .founder-shell { grid-template-columns: 1fr 1fr; } }

    .founder-q {
      padding: 72px 48px 72px 0;
    }
    @media (min-width: 768px) { .founder-q { border-right: 1px solid var(--bd); } }
    @media (max-width: 767px) { .founder-q { padding: 56px 0 0; } }

    blockquote.fq {
      font-family: 'Fraunces', serif; font-optical-sizing: auto;
      font-size: clamp(1.4rem, 3vw, 2.2rem);
      font-weight: 400; font-style: italic;
      line-height: 1.4; color: var(--white); margin-bottom: 28px;
    }
    blockquote.fq span { color: var(--amber); }
    .fq-attr {
      font-size: 0.73rem; font-weight: 400;
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--slate);
    }
    .fq-attr strong { color: var(--white); font-weight: 500; }

    .founder-stats {
      padding: 72px 0 72px 48px;
      display: flex; flex-direction: column; justify-content: center; gap: 32px;
    }
    @media (max-width: 767px) { .founder-stats { padding: 32px 0 56px; } }

    .f-stat-n {
      font-family: 'Fraunces', serif;
      font-size: 2.8rem; font-weight: 600; line-height: 1;
      color: var(--amber);
    }
    .f-stat-l { font-size: 0.78rem; font-weight: 300; color: var(--slate); margin-top: 3px; }

    /* ─── PRICING ────────────────────────────────────────── */
    #pricing { background: var(--navy-mid); }

    .price-badge {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 0.74rem; color: var(--amber);
      background: rgba(201,146,13,0.07);
      border: 1px solid var(--bd); padding: 7px 16px;
      border-radius: 20px; margin-bottom: 32px;
    }
    .ptable {
      width: 100%; border-collapse: collapse;
      border: 1px solid var(--bd);
    }
    .ptable thead tr { border-bottom: 1px solid var(--bd); background: rgba(201,146,13,0.05); }
    .ptable th {
      font-size: 0.65rem; font-weight: 500;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--amber); padding: 13px 20px; text-align: left;
    }
    .ptable tbody tr { border-bottom: 1px solid rgba(201,146,13,0.07); transition: background 0.18s; }
    .ptable tbody tr:last-child { border-bottom: none; }
    .ptable tbody tr:hover { background: rgba(201,146,13,0.025); }
    .ptable td { padding: 15px 20px; font-size: 0.875rem; }
    .ptable td:first-child { color: var(--white); }
    .ptable td:nth-child(2) { color: var(--slate); font-size: 0.78rem; }
    .ptable td:last-child {
      font-family: 'Fraunces', serif; font-size: 1.2rem;
      font-weight: 500; color: var(--amber); white-space: nowrap;
    }
    .price-note { margin-top: 12px; font-size: 0.72rem; font-weight: 300; color: var(--slate); }

    /* ─── COVERAGE ───────────────────────────────────────── */
    #coverage { background: var(--cream); }
    .cov-grid { display: grid; grid-template-columns: 1fr; gap: 48px; align-items: start; }
    @media (min-width: 768px) { .cov-grid { grid-template-columns: 1fr 1fr; } }

    .map-wrap {
      background: var(--ink); border: 1px solid var(--bdl);
      min-height: 300px; display: flex;
      align-items: center; justify-content: center; overflow: hidden;
    }
    .map-svg { width: 100%; max-width: 360px; padding: 24px; }

    .zone-list { display: flex; flex-direction: column; }
    .zone-row {
      display: flex; align-items: flex-start; gap: 14px;
      padding: 17px 0; border-bottom: 1px solid var(--bdl);
    }
    .zone-row:last-child { border-bottom: none; }
    .zpip { width: 7px; height: 7px; border-radius: 50%; background: var(--amber); margin-top: 6px; flex-shrink: 0; }
    .zpip.soft { background: #9AABA0; }
    .zname { font-size: 0.8rem; font-weight: 500; letter-spacing: 0.07em; text-transform: uppercase; color: var(--ink); margin-bottom: 2px; }
    .zdesc { font-size: 0.78rem; font-weight: 300; color: var(--muted-g); line-height: 1.6; }

    /* ─── DRIVERS ────────────────────────────────────────── */
    #drivers { background: var(--navy); }
    .dg { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px,1fr)); gap: 2px; }
    .dc {
      background: var(--navy-mid); border: 1px solid var(--bd);
      padding: 36px 26px; text-align: center;
      transition: border-color 0.25s, transform 0.25s;
    }
    .dc:hover { border-color: rgba(201,146,13,0.5); transform: translateY(-2px); }
    .da {
      width: 62px; height: 62px; border-radius: 50%;
      background: var(--navy-light); border: 1px solid var(--bd);
      margin: 0 auto 13px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Fraunces', serif; font-size: 1.4rem;
      font-weight: 400; font-style: italic; color: var(--amber);
    }
    .dn { font-family: 'Fraunces', serif; font-size: 1.08rem; font-weight: 500; color: var(--white); margin-bottom: 3px; }
    .dy { font-size: 0.63rem; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: var(--amber); margin-bottom: 12px; }
    .db { font-size: 0.58rem; font-weight: 400; letter-spacing: 0.12em; text-transform: uppercase; color: var(--slate); border: 1px solid rgba(201,146,13,0.14); padding: 4px 10px; border-radius: 10px; }

    /* ─── WHY NOT RIDESHARE ──────────────────────────────── */
    #why { background: var(--navy-mid); overflow: hidden; }
    .vs-wrap {
      display: grid; grid-template-columns: 1fr;
      border: 1px solid var(--bd); position: relative;
    }
    @media (min-width: 640px) { .vs-wrap { grid-template-columns: 1fr 1fr; } }

    .vs-div {
      display: none; position: absolute;
      left: 50%; top: 0; bottom: 0; transform: translateX(-50%);
      width: 1px; background: var(--bd); z-index: 2;
    }
    .vs-div::before {
      content: 'VS';
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      font-family: 'Fraunces', serif; font-style: italic;
      font-size: 0.85rem; font-weight: 400; color: var(--slate);
      background: var(--navy-mid); padding: 6px 10px;
      border: 1px solid var(--bd); border-radius: 2px;
    }
    @media (min-width: 640px) { .vs-div { display: block; } }

    .vs-col { padding: 42px 38px; }
    .vs-col.them { background: rgba(0,0,0,0.14); }
    .vs-col.us { background: rgba(201,146,13,0.03); }
    @media (max-width: 639px) { .vs-col.them { border-bottom: 1px solid var(--bd); } }

    .vs-head {
      font-size: 0.6rem; font-weight: 500;
      letter-spacing: 0.28em; text-transform: uppercase;
      padding-bottom: 16px; margin-bottom: 22px;
      border-bottom: 1px solid var(--bd);
    }
    .vh-them { color: var(--slate); }
    .vh-us { color: var(--amber); }

    .vr { display: flex; gap: 13px; align-items: flex-start; margin-bottom: 17px; font-size: 0.875rem; }
    .vr:last-child { margin-bottom: 0; }
    .vck { color: var(--amber); flex-shrink: 0; margin-top: 3px; }
    .vcx { color: #3A4E5E; flex-shrink: 0; margin-top: 3px; }
    .vt { color: var(--white); line-height: 1.5; }
    .vt span { display: block; color: var(--slate); font-size: 0.77rem; font-weight: 300; margin-top: 2px; }

    /* ─── CTA BAND ───────────────────────────────────────── */
    .cta-band {
      background: var(--navy); padding: 84px 32px;
      text-align: center; border-top: 1px solid var(--bd);
      position: relative; overflow: hidden;
    }
    .cta-band h2 {
      font-family: 'Fraunces', serif; font-optical-sizing: auto;
      font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 500;
      color: var(--white); margin-bottom: 16px;
      position: relative; z-index: 1;
    }
    .cta-band h2 em { font-style: italic; font-weight: 300; color: var(--amber); }
    .cta-band p {
      font-size: 0.95rem; font-weight: 300; color: var(--slate);
      max-width: 460px; margin: 0 auto 36px; line-height: 1.8;
      position: relative; z-index: 1;
    }
    .cta-band .btn-wa { position: relative; z-index: 1; }

    /* ─── FOOTER ─────────────────────────────────────────── */
    footer { background: var(--ink); padding: 56px 32px 32px; border-top: 1px solid rgba(201,146,13,0.12); }
    .fg { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 40px; }
    @media (min-width: 640px) { .fg { grid-template-columns: 2fr 1fr 1fr; } }
    .fb-name { font-family: 'Fraunces', serif; font-size: 1.25rem; font-weight: 500; color: var(--white); }
    .fb-loc { font-size: 0.57rem; font-weight: 400; letter-spacing: 0.22em; text-transform: uppercase; color: var(--amber); display: block; margin: 4px 0 14px; }
    .fb-p { font-size: 0.82rem; font-weight: 300; color: #4A6050; line-height: 1.75; max-width: 280px; }
    .fc h4 { font-size: 0.58rem; font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase; color: var(--amber); margin-bottom: 14px; }
    .fc ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
    .fc a { font-size: 0.82rem; font-weight: 300; color: #4A6050; text-decoration: none; transition: color 0.2s; }
    .fc a:hover { color: var(--white); }
    .fb-bot {
      max-width: 1100px; margin: 36px auto 0;
      padding-top: 22px; border-top: 1px solid rgba(201,146,13,0.07);
      display: flex; flex-wrap: wrap; gap: 12px;
      justify-content: space-between; align-items: center;
    }
    .fb-bot p { font-size: 0.7rem; font-weight: 300; color: #3A4A3A; }
    .lic-badge { font-size: 0.58rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--amber); border: 1px solid rgba(201,146,13,0.18); padding: 5px 12px; border-radius: 10px; }

    /* ─── FLOATING WA ────────────────────────────────────── */
